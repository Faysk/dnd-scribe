{
  "manifest_version": 3,
  "name": "DnD Scribe Roll20 Bridge",
  "version": "1.1.0",
  "description": "Captura chat e rolagens do Roll20 pelo navegador do GM e envia para o DnD Scribe.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://app.roll20.net/*",
    "https://dnd.faysk.dev/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://app.roll20.net/editor/*"],
      "js": ["content.js"],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ]
}
