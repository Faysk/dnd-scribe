# Discord notifications
# Webhooks can send DnD Scribe status messages to Discord.
# They cannot invoke Craig slash commands like /join or /stop.
DISCORD_WEBHOOK_URL=""
DND_DISCORD_WEBHOOK_URL=""
DND_DISCORD_WEBHOOK_NAME="DnD Scribe"

# Roll20 operator account
# Keep credentials in .env.local only.
ROLL20_OPERATOR_FIRST_NAME=""
ROLL20_OPERATOR_LAST_NAME=""
ROLL20_OPERATOR_EMAIL=""
ROLL20_OPERATOR_PASSWORD=""
ROLL20_JOIN_URL=""
ROLL20_GAME_ID=""
