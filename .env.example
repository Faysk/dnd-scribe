# App
NEXT_PUBLIC_APP_NAME="DnD Scribe"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# OpenAI
OPENAI_API_KEY=""
OPENAI_TRANSCRIPTION_MODEL="gpt-4o-mini-transcribe"
OPENAI_TEXT_MODEL="gpt-4o"

# Private AI cost overrides
# Keep current prices in .env.local, not in config/ai_cost_policy.json.
# Check https://openai.com/api/pricing/ before paid runs.
DND_COST_TRANSCRIPTION_AUDIO_MINUTE_USD=""
DND_COST_CLASSIFICATION_INPUT_MTOK_USD=""
DND_COST_CLASSIFICATION_OUTPUT_MTOK_USD=""
DND_COST_SUMMARY_INPUT_MTOK_USD=""
DND_COST_SUMMARY_OUTPUT_MTOK_USD=""

# Supabase client
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_PROJECT_REF=""
SUPABASE_JWKS_URL=""

# Supabase server/worker
SUPABASE_SECRET_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""
SUPABASE_DB_PASSWORD=""
DATABASE_URL=""
DATABASE_POOLER_URL=""
SUPABASE_POOLER_URL=""
DATABASE_DIRECT_URL=""

# Cloudflare R2 storage
R2_ACCOUNT_ID=""
R2_ENDPOINT=""
R2_S3_ENDPOINT=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="dnd-scribe-audio"
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_R2_ACCOUNT_TOKEN=""

# Vercel deploy/admin
VERCEL_TOKEN=""
VERCEL_PROJECT_ID=""
VERCEL_ORG_ID=""

# GitHub Actions production workers
# Used by the protected pipeline controls to dispatch long-running workers.
GITHUB_WORKFLOW_TOKEN=""
GITHUB_WORKFLOW_REPOSITORY="Faysk/dnd-scribe"
GITHUB_WORKFLOW_REF="main"

# Google OAuth for Supabase Auth
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""

# Discord OAuth for Supabase Auth
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""

# Discord bot / interactions
DISCORD_APPLICATION_ID=""
DISCORD_PUBLIC_KEY=""
DISCORD_BOT_TOKEN=""
DISCORD_GUILD_ID=""
DISCORD_DND_CHANNEL_ID=""
DISCORD_RECORDINGS_CHANNEL_ID=""
