# Keep secrets and local/runtime state out of Vercel uploads.
.env
.env.*
!.env.example

.git
.git/**
.vercel
.vercel/**
node_modules
node_modules/**

audio
audio/**
tmp
tmp/**
.agents
.agents/**
.codex
.codex/**

# Local/generated artifacts that are not needed by Vercel.
__pycache__
__pycache__/**
*.pyc
*.log

# The production build copies web/ into public/, so these must remain included.
!api
!api/**
!scripts
!scripts/**
!web
!web/**
!package.json
!package-lock.json
!vercel.json
