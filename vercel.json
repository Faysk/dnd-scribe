{
  "buildCommand": "npm run build",
  "outputDirectory": "public",
  "rewrites": [
    {
      "source": "/api/discord/interactions",
      "destination": "/api/ai-cost?discordInteractions=1"
    },
    {
      "source": "/api/pipeline-recover",
      "destination": "/api/ai-cost?pipelineRecover=1"
    },
    {
      "source": "/terms",
      "destination": "/terms.html"
    },
    {
      "source": "/privacy",
      "destination": "/privacy.html"
    },
    {
      "source": "/linked-role",
      "destination": "/linked-role.html"
    }
  ],
  "functions": {
    "api/**/*.js": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/pipeline-supervisor",
      "schedule": "15 4 * * *"
    }
  ]
}
